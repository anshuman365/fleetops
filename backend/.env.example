# ─── App Keys (generate random strings!) ───────────────────────────────
SECRET_KEY=change-this-to-a-long-random-secret-string
JWT_SECRET_KEY=another-long-random-jwt-secret-string

# ─── Database ───────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///trucklogs.db
# For PostgreSQL in production:
# DATABASE_URL=postgresql://user:password@host/dbname

# ─── Frontend URL ───────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── Email (Gmail SMTP example) ─────────────────────────────────────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your-app-password-here
MAIL_DEFAULT_SENDER=noreply@fleetops.app
# Gmail: enable 2FA, then create App Password at myaccount.google.com/apppasswords

# ─── Razorpay ───────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_your_key_here
RAZORPAY_KEY_SECRET=your_razorpay_secret_here
# Get keys from: https://dashboard.razorpay.com/app/keys
